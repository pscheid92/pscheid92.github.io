---
import {Image} from 'astro:assets';
import type {CollectionEntry} from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Layout from './Layout.astro';

interface Props extends CollectionEntry<'blog'>['data'] {
    headings?: { depth: number; slug: string; text: string }[];
    readTime?: number;
}

const {title, description, pubDate, updatedDate, heroImage, tags = [], headings = [], readTime} = Astro.props;
---

<Layout title={title} description={description} pageClass="page-blog-post">
    <ReadingProgress />
    <article>
        <header class="article-header">
            <div class="article-meta">
                {tags.length > 0 && (
                    <span class="article-tags">
                        {tags.map((tag) => (
                            <a href="/blog/" class="article-tag">{tag}</a>
                        ))}
                    </span>
                )}
                <div class="article-date-info">
                    {pubDate && (
                        <time>
                            <FormattedDate date={pubDate} />
                        </time>
                    )}
                    {updatedDate && (
                        <span class="last-updated">
                            (updated <FormattedDate date={updatedDate} />)
                        </span>
                    )}
                    {readTime && (
                        <>
                            <span class="meta-dot">&middot;</span>
                            <span>{readTime} min read</span>
                        </>
                    )}
                </div>
            </div>
            <h1 class="article-title">{title}</h1>
            {description && (
                <p class="article-description">{description}</p>
            )}
        </header>

        {heroImage && (
            <div class="hero-image">
                <Image width={1020} height={510} src={heroImage} alt="" />
            </div>
        )}

        <div class="article-body">
            {headings.length > 0 && (
                <aside class="article-sidebar">
                    <div class="sidebar-sticky">
                        <TableOfContents headings={headings} />
                    </div>
                </aside>
            )}
            <div class="prose">
                <slot />
            </div>
        </div>

        <footer class="article-footer">
            <a href="/blog/" class="back-link">&larr; Back to all articles</a>
        </footer>
    </article>
</Layout>

<style>
    article {
        width: 100%;
    }

    /* Article header */
    .article-header {
        max-width: 54rem;
        margin: 0 auto 2rem;
        text-align: center;
    }

    .article-meta {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.25rem;
    }

    .article-tags {
        display: flex;
        gap: 0.5rem;
    }

    .article-tag {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-accent);
        text-decoration: none;
        padding: 0.2em 0.7em;
        border: 1px solid var(--color-accent);
        border-radius: 999px;
        transition: all 0.2s ease;
    }

    .article-tag:hover {
        background: var(--color-accent);
        color: #fff;
    }

    .article-date-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        color: var(--color-text-muted);
    }

    .last-updated {
        font-style: italic;
    }

    .meta-dot {
        opacity: 0.4;
    }

    .article-title {
        font-size: 2.5rem;
        font-weight: 700;
        line-height: 1.15;
        margin: 0 0 0.75rem;
        letter-spacing: -0.025em;
        color: var(--color-text-heading);
    }

    .article-description {
        font-size: 1.15rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin: 0;
    }

    /* Hero image */
    .hero-image {
        margin: 0 auto 2.5rem;
        max-width: 56rem;
    }

    .hero-image img {
        display: block;
        width: 100%;
        border-radius: 12px;
        box-shadow: var(--box-shadow);
    }

    /* Article body with sidebar */
    .article-body {
        display: grid;
        grid-template-columns: 1fr minmax(0, 54rem) 1fr;
        gap: 0;
        max-width: 76rem;
        margin: 0 auto;
    }

    .article-sidebar {
        grid-column: 3;
        grid-row: 1;
        padding-left: 2.5rem;
    }

    .sidebar-sticky {
        position: sticky;
        top: 2rem;
    }

    .prose {
        grid-column: 2;
        color: var(--color-text);
        min-width: 0;
    }

    .prose :global(img) {
        border-radius: 10px;
    }

    /* Article footer */
    .article-footer {
        max-width: 54rem;
        margin: 3rem auto 0;
        padding-top: 2rem;
        border-top: 1px solid var(--color-border);
    }

    .back-link {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--color-text-muted);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .back-link:hover {
        color: var(--color-accent);
    }

    /* Responsive */
    @media (max-width: 1100px) {
        .article-body {
            display: block;
            max-width: 54rem;
            margin: 0 auto;
        }

        .article-sidebar {
            padding-left: 0;
            margin-bottom: 2rem;
            padding: 1.25rem;
            background: var(--color-surface);
            border-radius: 8px;
            border: 1px solid var(--color-border);
        }

        .sidebar-sticky {
            position: static;
        }
    }

    @media (max-width: 720px) {
        .article-title {
            font-size: 1.85rem;
        }

        .article-description {
            font-size: 1.05rem;
        }

        .article-header {
            text-align: left;
        }

        .article-meta {
            align-items: flex-start;
        }
    }
</style>
