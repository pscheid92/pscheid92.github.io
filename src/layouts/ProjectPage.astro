---
import type {CollectionEntry} from 'astro:content';
import Layout from './Layout.astro';

interface Props extends CollectionEntry<'projects'>['data'] {
    headings?: { depth: number; slug: string; text: string }[];
}

const languageColors: Record<string, string> = {
    'TypeScript': '#3178c6',
    'Go': '#00ADD8',
    'C#': '#68217a',
    'YAML': '#cb171e',
};

const {title, description, language, secondaryLanguage, github, liveUrl, kind, topics = [], headings = []} = Astro.props;
---

<Layout title={`${title} - Patrick Scheid`} description={description} pageClass="page-project">
    <article>
        <header class="project-header">
            <div class="project-meta">
                <div class="project-languages">
                    <span class="language">
                        <span class="language-dot" style={`background:${languageColors[language] || '#888'}`}></span>
                        {language}
                    </span>
                    {secondaryLanguage && (
                        <span class="language">
                            <span class="language-dot" style={`background:${languageColors[secondaryLanguage] || '#888'}`}></span>
                            {secondaryLanguage}
                        </span>
                    )}
                    <span class="meta-dot">&middot;</span>
                    {liveUrl ? (
                        <a href={liveUrl} class="kind-badge kind-live" target={liveUrl.startsWith('/') ? undefined : '_blank'} rel={liveUrl.startsWith('/') ? undefined : 'noopener noreferrer'}>
                            {kind}
                        </a>
                    ) : (
                        <span class="kind-badge">{kind}</span>
                    )}
                </div>
            </div>
            <h1 class="project-title">{title}</h1>
            <p class="project-description">{description}</p>
            <div class="project-links">
                {github && (
                    <a href={github} target="_blank" rel="noopener noreferrer" class="project-link">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                        </svg>
                        <span>Source Code</span>
                    </a>
                )}

                {liveUrl && (
                    <a href={liveUrl} target={liveUrl.startsWith('/') ? undefined : '_blank'} rel={liveUrl.startsWith('/') ? undefined : 'noopener noreferrer'} class="project-link project-link-primary">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                            <polyline points="15 3 21 3 21 9"/>
                            <line x1="10" y1="14" x2="21" y2="3"/>
                        </svg>
                        <span>Visit</span>
                    </a>
                )}
            </div>
            {topics.length > 0 && (
                <div class="project-topics">
                    {topics.map((topic) => (
                        <span class="topic-tag">{topic}</span>
                    ))}
                </div>
            )}
        </header>

        <div class="project-body">
            <div class="prose">
                <slot />
            </div>
        </div>

        <footer class="project-footer">
            <a href="/projects/" class="back-link">&larr; Back to all projects</a>
        </footer>
    </article>
</Layout>

<style>
    article {
        width: 100%;
        max-width: 48rem;
        margin: 0 auto;
    }

    .project-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }

    .project-meta {
        display: flex;
        justify-content: center;
        margin-bottom: 1rem;
    }

    .project-languages {
        display: flex;
        align-items: center;
        gap: 0.5em;
    }

    .language {
        display: flex;
        align-items: center;
        gap: 0.35em;
        font-size: 0.85rem;
        color: var(--color-text);
        font-weight: 700;
        line-height: 1;
    }

    .language-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
        margin-bottom: 2px;
    }

    .meta-dot {
        opacity: 0.4;
        color: var(--color-text-muted);
    }

    .kind-badge {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 0.2em 0.6em;
        border-radius: 4px;
        background: var(--color-code-bg);
        color: var(--color-text-muted);
        text-decoration: none;
        white-space: nowrap;
    }

    .kind-live {
        background: color-mix(in srgb, var(--color-accent) 12%, transparent);
        color: var(--color-accent);
    }

    .project-title {
        font-size: 2.5rem;
        font-weight: 700;
        line-height: 1.15;
        margin: 0 0 0.75rem;
        letter-spacing: -0.025em;
        color: var(--color-text-heading);
    }

    .project-description {
        font-size: 1.15rem;
        line-height: 1.6;
        color: var(--color-text-muted);
        margin: 0 0 1.25rem;
    }

    .project-links {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        margin-bottom: 1.25rem;
    }

    .project-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;

        gap: 0.5em;
        font-size: 0.9rem;
        font-weight: 600;

        line-height: 1;

        padding: 0.65em 1em;
        border-radius: 8px;

        border: 1px solid var(--color-border);
        color: var(--color-text);
        text-decoration: none;

        transition: border-color 0.2s ease, background 0.2s ease;
    }

    .project-link :global(svg) {
        flex-shrink: 0;
    }

    .project-link span {
        height: 18px;
        line-height: 18px;
        overflow: hidden;
        padding-top: 1px;
    }

    .project-link:hover {
        border-color: var(--color-accent);
        background: color-mix(in srgb, var(--color-accent) 6%, transparent);
        color: var(--color-text-heading);
    }

    .project-link-primary {
        background: var(--color-accent);
        border-color: var(--color-accent);
        color: #fff;
    }

    .project-link-primary:hover {
        background: var(--color-accent-dark);
        border-color: var(--color-accent-dark);
        color: #fff;
    }

    .project-topics {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.4em;
    }

    .topic-tag {
        font-size: 0.72rem;
        padding: 0.15em 0.55em;
        border-radius: 4px;
        background: var(--color-code-bg);
        color: var(--color-text-muted);
        white-space: nowrap;
    }

    .project-body {
        margin: 0 auto;
    }

    .prose {
        color: var(--color-text);
    }

    .project-footer {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--color-border);
    }

    .back-link {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--color-text-muted);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .back-link:hover {
        color: var(--color-accent);
    }

    @media (max-width: 720px) {
        .project-title {
            font-size: 1.85rem;
        }

        .project-description {
            font-size: 1.05rem;
        }

        .project-header {
            text-align: left;
        }

        .project-meta {
            justify-content: flex-start;
        }

        .project-links {
            justify-content: flex-start;
        }

        .project-topics {
            justify-content: flex-start;
        }
    }
</style>
