---
import {getCollection} from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const languageColors: Record<string, string> = {
    'TypeScript': '#3178c6',
    'Go': '#00ADD8',
    'C#': '#68217a',
    'YAML': '#cb171e',
};

// Define display order
const order = ['agesharp', 'secretli', 'pgharden', 'uuid', 'chatpulse', 'k8s-cluster'];
const allProjects = await getCollection('projects');
const projects = order.map((id) => allProjects.find((p) => p.id === id)!).filter(Boolean);
---

<Layout
    title="Projects - Patrick Scheid"
    description="Open-source projects by Patrick Scheid — libraries, tools, and applications in Go, C#, and TypeScript."
    pageClass="page-projects"
>
    <section class="projects-header">
        <h1>Projects</h1>
        <p class="projects-intro">
            A selection of open-source tools and libraries I've built —
            from cryptography and security to real-time systems and developer utilities.
        </p>
    </section>

    <section class="projects-grid">
        {projects.map((project) => (
            <a href={`/projects/${project.id}/`} class="project-card-link">
                <article class="project-card">
                    <div class="project-card-body">
                        <div class="project-name-row">
                            <h2>{project.data.title}</h2>
                            {project.data.liveUrl ? (
                                <span class="kind-badge kind-live">{project.data.kind}</span>
                            ) : (
                                <span class="kind-badge">{project.data.kind}</span>
                            )}
                        </div>
                        <p class="project-description">{project.data.description}</p>
                    </div>
                    <div class="project-card-footer">
                        <div class="project-meta-left">
                            <div class="project-languages">
                                <span class="language">
                                    <span class="language-dot" style={`background:${languageColors[project.data.language] || '#888'}`} />
                                    {project.data.language}
                                </span>
                                {project.data.secondaryLanguage && (
                                    <span class="language">
                                        <span class="language-dot" style={`background:${languageColors[project.data.secondaryLanguage] || '#888'}`} />
                                        {project.data.secondaryLanguage}
                                    </span>
                                )}
                            </div>
                            <div class="project-topics">
                                {project.data.topics.slice(0, 4).map((topic) => (
                                    <span class="topic-tag">{topic}</span>
                                ))}
                            </div>
                        </div>
                        {project.data.github && (
                            <span class="github-link" aria-hidden="true">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                                </svg>
                            </span>
                        )}
                    </div>
                </article>
            </a>
        ))}
    </section>
</Layout>

<style>
    .projects-header {
        text-align: center;
        padding: 2em 0 2.5em;
    }

    .projects-header h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5em;
    }

    .projects-intro {
        font-size: 1.15rem;
        color: var(--color-text-muted);
        max-width: 34rem;
        margin: 0 auto;
        line-height: 1.6;
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
        padding-bottom: 3em;
    }

    .project-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .project-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 1.5em;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    .project-card-link:hover .project-card {
        transform: translateY(-3px);
        box-shadow: var(--box-shadow);
        border-color: var(--color-accent);
    }

    .project-card-body {
        flex: 1;
    }

    .project-name-row {
        display: flex;
        align-items: center;
        gap: 0.75em;
        margin-bottom: 0.5em;
        flex-wrap: wrap;
    }

    .project-name-row h2 {
        font-size: 1.3rem;
        margin: 0;
        color: var(--color-text-heading);
    }

    .kind-badge {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 0.2em 0.6em;
        border-radius: 4px;
        background: var(--color-code-bg);
        color: var(--color-text-muted);
        white-space: nowrap;
    }

    .kind-live {
        background: color-mix(in srgb, var(--color-accent) 12%, transparent);
        color: var(--color-accent);
    }

    .project-description {
        color: var(--color-text-muted);
        font-size: 0.95rem;
        line-height: 1.55;
        margin: 0 0 1.25em;
    }

    .project-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75em;
        padding-top: 1em;
        border-top: 1px solid var(--color-border);
    }

    .project-meta-left {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.75em;
        flex: 1;
        min-width: 0;
    }

    .project-languages {
        display: flex;
        gap: 0.75em;
        align-items: center;
    }

    .github-link {
        color: var(--color-text-muted);
        flex-shrink: 0;
        display: flex;
    }

    .language {
        display: flex;
        align-items: center;
        gap: 0.35em;
        font-size: 0.85rem;
        color: var(--color-text);
        font-weight: 700;
        line-height: 1;
    }

    .language-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
        margin-bottom: 2px;
    }

    .project-topics {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4em;
    }

    .topic-tag {
        font-size: 0.72rem;
        padding: 0.15em 0.55em;
        border-radius: 4px;
        background: var(--color-code-bg);
        color: var(--color-text-muted);
        white-space: nowrap;
    }

    @media (max-width: 720px) {
        .projects-grid {
            grid-template-columns: 1fr;
        }

        .projects-header h1 {
            font-size: 2rem;
        }
    }
</style>
